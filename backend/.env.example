PORT=3001
BACKEND_URL=http://localhost:3001
MOBILE_DEEP_LINK=communityremit://payment

# Open Payments (Interledger Test Wallet)
OP_WALLET_ADDRESS=https://ilp.interledger-test.dev/your-wallet
OP_KEY_ID=your-key-uuid
OP_PRIVATE_KEY_PATH=./private.key

# Auth
JWT_SECRET=change-me-to-a-long-random-string

# Firebase (optional — falls back to in-memory store if unset)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# WhatsApp Cloud API (optional for POC)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=community-remit-verify
